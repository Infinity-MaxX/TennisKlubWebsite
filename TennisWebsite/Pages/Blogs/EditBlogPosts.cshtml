@page
@model TennisWebsite.Pages.Blogs.EditBlogPostsModel
@{
	ViewData["Title"] = "EditPost";
}

<form method="post" enctype="multipart/form-data">
    <div class="form-group">
        <div asp-validation-summary="All" class="text-danger"></div>
        <label asp-for="@Model.Post.ID" class="control-label"></label>
        <input asp-for="@Model.Post.ID" class="form-control" required="true" readonly="true" />
    </div>
    <div class="form-group">
        <label asp-for="@Model.Post.Author" class="control-label"></label>
        <input asp-for="@Model.Post.Author" class="form-control" required="true" />
    </div>
    <div class="form-group">
        <label asp-for="@Model.Post.Title" class="control-label"></label>
        <input asp-for="@Model.Post.Title" class="form-control" required="false" />
    </div>
    <div class="form-group">
        <label asp-for="@Model.Post.Body" class="control-label"></label>
        <input asp-for="@Model.Post.Body" class="form-control" required="true" />
    </div>
    <div class="form-group">
        <label asp-for="@Model.Post.Date" class="control-label"></label>
        <input asp-for="@Model.Post.Date" class="form-control" required="true" readonly="true" />
    </div>
    <div class="formgroup">
        <input type="submit" value="Opdater" class="btn btn-primary" />
    </div>
</form>