@page
@model TennisWebsite.Pages.Blogs.EditBlogPostsModel
@{
	ViewData["Title"] = "EditBlogPosts";
}

<form method="post" enctype="multipart/form-data">
    <div class="container p-4 Container-Background">
        <div style="width: 30vw">
            <div class="form-group">
                <input asp-for="@Model.Post.ID" hidden="true" readonly="true"/>
            </div>
            <div class="form-group">
                <label for="exampleFormControlTextarea1">Forfatter</label>
                <input asp-for="@Model.Post.Author" class="form-control" required="true" readonly="true"/>
            </div>
            <div class="form-group">
                <label for="exampleFormControlTextarea1">Titel</label>
                <input asp-for="@Model.Post.Title" class="form-control" required="false" />
            </div>
            <div class="form-group">
                <div class="form-group">
                    <label for="exampleFormControlTextarea1">Indhold</label>
                    <textarea asp-for="@Model.Post.Body" class="form-control" id="exampleFormControlTextarea1" rows="3"></textarea>
                </div>
            </div>
            <div class="form-group">
                <label for="exampleFormControlTextarea1">Dato</label>
                <input asp-for="@Model.Post.Date" class="form-control" required="true" readonly="true" />
            </div>
            <div class="formgroup">
                <input type="submit" value="Opdater" class="btn btn-primary mt-2" />
            </div>
        </div>
    </div>
</form>