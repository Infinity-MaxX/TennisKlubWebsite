@page
@model TennisWebsite.Pages.Users.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="container p-4 Container-Background">
    <h4 class="text-danger">
        @Model.LoginStatus
    </h4>

    <form method="post">
        <div class="form-group">
            <label asp-for="@Model.LoginUsername" class="control-label"></label>
            <input asp-for="@Model.LoginUsername" class="form-control" />
        </div>

        <div class="form-group">
            <label asp-for="@Model.LoginPass" class="control-label"></label>
            <input asp-for="@Model.LoginPass" class="form-control" />
        </div>

        <input type="submit" value="Login" class="btn btn-primary" asp-route-OriginalDestination="@Model.OriginalDestination"/>
        <a asp-page="/Users/RegisterNewUser" class="btn btn-primary">Register</a>
    </form>
</div>
