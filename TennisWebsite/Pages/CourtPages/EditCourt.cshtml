@page
@model TennisWebsite.Pages.CourtPages.EditCourtModel
@{
}
<div class="container Container-Background">

    <form method="post" class="mt-4">
        <input type="text" hidden="true" asp-for="@Model.OldCourt"/>
        <div class="input-group">
            <div class="input-group-text">
                <div class="form-check form-check-inline">
                    <input type="radio" asp-for="newCourt.Type" class="form-check-input"
                           id="TennisRadios1" value="Tennis" />
                    <label class="form-check-label" for="TennisRadios1">
                        Tennis
                    </label>
                </div>

                <div class="form-group form-check-inline">
                    <input type="radio" asp-for="newCourt.Type" class="form-check-input"
                           id="TennisRadios2" value="Paddle" />
                    <label class="form-check-label" for="TennisRadios2">
                        Paddle
                    </label>
                </div>


                <div class="form-floating">
                    <input asp-for="newCourt.Name" class="form-control" required="true" id="CourtName" placeholder="newCourt.Name" />
                    <label for="CourtName">Bane navn</label>
                    <span asp-validation-for="newCourt.Name" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label class="form-check-label">
                        Sidste service
                    </label>
                    <input type="date" asp-for="newCourt.LastMaintenance"/>
                </div>
            </div>
        </div>

        <div class="formgroup mt-2">
            <input type="submit" value="opræt bane" class="btn btn-primary" />
        </div>
    </form>
</div>