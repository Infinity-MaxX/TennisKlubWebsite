@page
@model TennisWebsite.Pages.CourtPages.AddCourtModel
@{
}


<form method="post">
    <div class="form-check form-check-inline">
        <input type="radio" asp-for="newCourt.Type" class="form-check-input" 
        id="TennisRadios1" value="Tennis" />
        <label class="form-check-label" for="TennisRadios1">
            Tennis
        </label>
    </div>
    <div class="form-group form-check-inline">
        <input type="radio" asp-for="newCourt.Type" class="form-check-input"
               id="TennisRadios2" value="Paddle" />
        <label class="form-check-label" for="TennisRadios2">
            Paddle
        </label>
    </div>

    <div class="form-group">
        <label asp-for="newCourt.Name" class="control-label"></label>
        <input asp-for="newCourt.Name" class="form-control" required="true" />
        <span asp-validation-for="newCourt.Name" class="text-danger"></span>
    </div>


    <div class="formgroup">
        <input type="submit" value="opræt bane" class="btn btn-primary" />
    </div>
</form>